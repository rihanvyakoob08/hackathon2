SECRET_KEY=krishimitra-secret-key-change-in-production
DATABASE_URL=sqlite:///./krishimitra.db

# Sarvam AI powers chat, scheme checks, weather advisory, STT, and TTS.
SARVAM_API_KEY=
SARVAM_CHAT_MODEL=sarvam-30b

# Optional: enables real crop image diagnosis fallback when google-generativeai is installed.
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash

# Optional newline-separated city/district list for weather location extraction.
INDIAN_CITIES_PATH=

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Twilio voice configuration for outbound IVR and WhatsApp messaging.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PUBLIC_BASE_URL=
PUBLIC_WEBHOOK_PREFIX=

# Twilio WhatsApp Sandbox/Business sender, e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=


